# Copy this file to .env and fill in your own values. NEVER commit the real .env file.

# Server
PORT=3000
NODE_ENV=development

# Python RAG Engine
RAG_ENGINE_URL=http://localhost:5001

# Must match ADMIN_API_KEY in rag-engine/.env
ADMIN_API_KEY=

# Twilio (fill in when you set up WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
